{
    "cleanUrls": true,
    "trailingSlash": false,
    "framework": "vite",
    "devCommand": "npm run dev",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/:path*"
        },
        {
            "source": "/:path*",
            "destination": "/index.html"
        }
    ]
}