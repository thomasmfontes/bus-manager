{
    "cleanUrls": true,
    "trailingSlash": false,
    "framework": "vite",
    "devCommand": "npm run dev",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/|.*\\.).*)",
            "destination": "/index.html"
        }
    ]
}